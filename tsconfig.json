{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "composite": true,
    "noEmit": false
  },
  "references": [
    { "path": "packages/core" },
    { "path": "packages/worker" },
    { "path": "packages/scheduler" }
  ]
}
